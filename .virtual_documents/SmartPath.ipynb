def generate_recommendations(user_input, job_profiles):
    # 1. Extracting user inputs
    user_riasec = np.array(user_input['riasec']).reshape(1, -1)
    user_edu = user_input['education_level']
    user_skills = user_input['skills']

    # 2. Extracting RIASEC columns and normalize
    riasec_cols = ['R', 'I', 'A', 'S', 'E', 'C']
    job_riasec_matrix = job_profiles[riasec_cols].fillna(0).values
    user_riasec = MinMaxScaler().fit_transform(user_riasec)  

    # 3. Computing cosine similarity between user and jobs (RIASEC)
    riasec_sim = cosine_similarity(user_riasec, job_riasec_matrix).flatten()

    # 4. Matching education level to job requirement
    edu_match_score = job_profiles['Education Category Label'].apply(
        lambda x: 1 if str(user_edu).lower() in str(x).lower() else 0
    )

    # 5. Computing skill match score (percentage of user skills found in each job's skill set)
    if user_skills:
        job_skills_df = job_profiles[user_skills].fillna(0)  # these should be one-hot encoded
        skill_match_score = job_skills_df.sum(axis=1) / len(user_skills)
    else:
        skill_match_score = pd.Series(0, index=job_profiles.index)

    # 6. Combining all components into hybrid score
    job_profiles['RIASEC Similarity'] = riasec_sim
    job_profiles['Education Match'] = edu_match_score
    job_profiles['Skill Match'] = skill_match_score

    # Tuning weights
    job_profiles['Hybrid Score'] = (
        0.5 * job_profiles['RIASEC Similarity'] +
        0.3 * job_profiles['Education Match'] +
        0.2 * job_profiles['Skill Match']
    )

    # 7. Return top 5 jobs
    top_matches = job_profiles.sort_values('Hybrid Score', ascending=False).head(5)

    return top_matches[['Title', 'Hybrid Score', 'RIASEC Similarity', 'Education Match', 'Skill Match']]





user_input = get_user_profile()
recommendations = generate_recommendations(user_input, job_profiles_clean)
recommendations.style.background_gradient(cmap='YlGn')



