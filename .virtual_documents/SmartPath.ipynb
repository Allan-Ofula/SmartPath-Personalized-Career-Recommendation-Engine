def get_user_profile():
    # Ask user to input their RIASEC scores (Realistic, Investigative, Artistic, Social, Enterprising, Conventional)
    print("🎯 Enter your RIASEC Scores (scale of 0–7, separated by commas):")
    print("Format: R, I, A, S, E, C")
    r_i_a_s_e_c = input("Enter scores: ").strip().split(',')
    
    try:
        # Splitting input string by comma, convert each to float, and store as a list
        riasec_scores = list(map(float, riasec_input.strip().split(',')))
        if len(riasec_scores) != 6:
            raise ValueError  # Ensure all 6 dimensions are provided
    except:
        print("⚠️ Please enter six numeric values separated by commas.")
        return None

    # Let user select their highest education level from a predefined list
    print("\n🎓 Select your highest education level:")
    edu_levels = {
        1: "Less than High School",
        2: "High School or Equivalent",
        3: "Some College",
        4: "Associate Degree",
        5: "Bachelor's Degree",
        6: "Master's Degree",
        7: "Doctoral or Professional Degree"
    }
    # Display education options
    for key, val in edu_levels.items():
        print(f"{key}. {val}")
    
    try:
        # Getting user's numeric choice and map to education level
        edu_choice = int(input("Enter number (1–7): "))
        edu_level = edu_levels.get(edu_choice)
        if not edu_level:
            raise ValueError
    except:
        print("⚠️ Invalid education level.")
        return None

    # Ask user to select their top skills (optional)
    print("\n🛠️ Select up to 3 skills you consider strong (or press Enter to skip):")
    common_skills = [
        "Reading Comprehension", "Critical Thinking", "Writing", "Active Listening", 
        "Coordination", "Problem Solving", "Speaking", "Systems Analysis"
    ]
    # Display available skills with numbering
    for i, skill in enumerate(common_skills, 1):
        print(f"{i}. {skill}")
    
    # Get skill numbers from user input
    skill_input = input("Enter skill numbers separated by commas (e.g., 1,3,5): ")
    selected_skills = []
    if skill_input:
        try:
            indices = list(map(int, skill_input.strip().split(',')))
            # Match skill numbers to actual skill names
            selected_skills = [common_skills[i-1] for i in indices if 0 < i <= len(common_skills)]
        except:
            print("⚠️ Skills input not valid. Continuing with none.")

    # Final confirmation message
    print("\n✅ Thank you. Generating personalized recommendations...")
    
    # Return all user input in a dictionary
    return {
        'riasec': riasec_scores,
        'education_level': edu_level,
        'skills': selected_skills
    }





